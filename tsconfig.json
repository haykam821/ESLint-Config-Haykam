{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"lib": [
			"es2022"
		],
		"module": "preserve",
		"noImplicitAny": true,
		"outDir": "./dist",
		"rewriteRelativeImportExtensions": true,
		"rootDir": "./src",
		"strict": true,
		"target": "es2022",
		"types": [
			"@types/node"
		]
	},
	"include": [
		"./src"
	]
}
