{
	"name": "eslint-config-haykam",
	"version": "1.25.0",
	"description": "My personal configuration for ESLint.",
	"main": "./dist/eslint-config.js",
	"scripts": {
		"lint": "eslint \"./**/*.ts\" --ignore-path .gitignore",
		"prepack": "rimraf dist && tsc"
	},
	"keywords": [
		"eslint",
		"config",
		"eslintconfig",
		"standard",
		"lint",
		"linter"
	],
	"peerDependencies": {
		"eslint": "^8.55.0"
	},
	"dependencies": {
		"@rushstack/eslint-patch": "^1.1.0",
		"@stylistic/eslint-plugin": "^3.0.0",
		"eslint-plugin-extra-rules": "0.0.0-development",
		"eslint-plugin-html": "^8.1.2",
		"eslint-plugin-jsdoc": "^50.6.10",
		"eslint-plugin-json": "^4.0.1",
		"eslint-plugin-markdown": "^4.0.1",
		"eslint-plugin-node": "^11.1.0",
		"eslint-plugin-perfectionist": "^5.7.0",
		"eslint-plugin-unicorn": "^56.0.1"
	},
	"devDependencies": {
		"@types/eslint": "^8.56.12",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"author": "haykam821",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/haykam821/ESLint-Config-Haykam.git"
	},
	"bugs": {
		"url": "https://github.com/haykam821/ESLint-Config-Haykam/issues"
	},
	"homepage": "https://github.com/haykam821/ESLint-Config-Haykam#readme",
	"files": [
		"dist/**/*"
	],
	"eslintConfig": {
		"extends": [
			"./dist/eslint-config.js",
			"plugin:@typescript-eslint/eslint-recommended",
			"plugin:@typescript-eslint/recommended"
		],
		"parser": "@typescript-eslint/parser",
		"plugins": [
			"@typescript-eslint"
		],
		"rules": {
			"@typescript-eslint/no-require-imports": "off"
		}
	}
}
